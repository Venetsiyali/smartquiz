generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  MODERATOR
}

enum Plan {
  FREE
  PRO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  
  role          Role      @default(STUDENT)
  plan          Plan      @default(FREE)
  proUntil      DateTime?
  
  lastLogin     DateTime?
  totalGamesPlayed Int    @default(0)

  // ── Gamification (yangi qo'shildi, mavjud ustunlar saqlanadi) ──
  streak         Int       @default(0)
  lastStreakDate DateTime?
  xp             Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  quizzes       Quiz[]
  badges        UserBadge[]
}

// ==========================================
// GAMIFICATION — yangi modellar
// ==========================================

model Badge {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String
  icon        String
  color       String

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeKey  String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeKey], references: [key])

  @@unique([userId, badgeKey])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// LIBRARY QUIZZES (Kutubxona — alohida jadval)
// ==========================================

model LibraryQuiz {
  id          String   @id @default(cuid())
  title       String
  subject     String
  grade       String   @default("Barcha")
  game_type   String   @default("Klassik")
  badge_type  String   @default("Yangi qo'shildi")
  play_count  Int      @default(0)
  rating      Float    @default(0)
  is_pinned   Boolean  @default(false)
  is_seasonal Boolean  @default(false)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  questions   Json

  @@map("library_quizzes")
}

// ==========================================
// GAME SAVING (Savollar Xazinasi)
// ==========================================

model Quiz {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  isPublic    Boolean  @default(false)
  
  // JSON formatida 6 turdagi o'yin savollari saqlanadi
  questions   Json     

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

